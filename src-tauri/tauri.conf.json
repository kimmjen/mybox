{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MYBOX Extractor",
  "version": "1.0.0",
  "identifier": "com.mybox.extractor",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "NAVER MYBOX Extractor",
        "width": 680,
        "height": 780,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../extract.cjs",
      "../compile.py"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
